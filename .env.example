# Database
POSTGRES_DB=sceneradar
POSTGRES_USER=sceneradar
POSTGRES_PASSWORD=sceneradar
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Required for real event ingestion
TICKETMASTER_API_KEY=

# Required for real genre tags and popularity
LASTFM_API_KEY=

# MusicBrainz does not use an API key, but it expects a meaningful User-Agent.
# Use your real email/contact for responsible API usage.
MUSICBRAINZ_APP_NAME=SceneRadarStudentProject
MUSICBRAINZ_CONTACT_EMAIL=

# Overpass / OpenStreetMap does not require an API key.
OVERPASS_URL=https://overpass-api.de/api/interpreter
